<item>
    <title>学校校区地址</title>
    <link>https://bistublog.xyz/posts/%E5%AD%A6%E6%A0%A1%E5%9C%B0%E5%9D%80/</link>
    <pubDate>Fri, 05 Jun 2026 00:00:00 &#43;0000</pubDate>
    <author>lile.stu@qq.com (lile)</author>
    <guid>https://bistublog.xyz/posts/%E5%AD%A6%E6%A0%A1%E5%9C%B0%E5%9D%80/</guid>
    <description><![CDATA[<div id="amap-container" style="width: 100%; height: 450px; margin: 20px 0; border-radius: 8px; border: 1px solid #ddd;"></div>

<script type="text/javascript">
    
    window._AMapSecurityConfig = {
        securityJsCode: 'c3f87bdf5bc3cf9a34bc6e87a2d8ccbe',
    }
</script>
<script type="text/javascript" src="https://webapi.amap.com/maps?v=1.4.15&key=fbe3d2425a8dbb4816be6cfcf856b3b5"></script>
<script type="text/javascript">
    const markerData = [
        
    {"coords": [116.238416,40.141085], "name": "北京信息科技大学沙河校区"},
    {"coords": [116.347047,40.038011], "name": "北京信息科技大学小营校区"},
    {"coords": [116.382489,39.98881], "name": "北京信息科技大学健翔桥校区(现中国音乐学院健翔桥新校区)"},
    {"coords": [116.489077,39.96484], "name": "北京信息科技大学酒仙桥校区"},
    {"coords": [116.469759,39.921243], "name": "北京信息科技大学金台路校区"},
    {"coords": [115.643653,40.376666], "name": "北京信息科技大学张家口校区"}

    ];

    const defaultCenter = markerData.length > 0 ? markerData[0].coords : [116.397428, 39.90923];

    
    const map = new AMap.Map('amap-container', {
        resizeEnable: true,
        zoom: 12,
        center: defaultCenter
    });
    
    
    markerData.forEach(item => {
        const marker = new AMap.Marker({
            position: item.coords,
            title: item.name,
            map: map
        });

        marker.setLabel({
            direction: 'top',
            offset: new AMap.Pixel(0, -5),
            content: `<div style='padding:5px; background:#fff; border:1px solid #ccc; border-radius:4px; color:#333; font-size:12px;'>${item.name}</div>`,
        });
    });

    if (markerData.length > 1) {
        map.setFitView();
    }
    
    
    AMap.plugin(['AMap.ToolBar', 'AMap.Scale'], function(){
        map.addControl(new AMap.ToolBar());
        map.addControl(new AMap.Scale());
    });
</script>
<h3 id="学校地址">学校地址</h3>
<p>沙河校区：北京市昌平区太行路55号</p>]]></description>
</item>
